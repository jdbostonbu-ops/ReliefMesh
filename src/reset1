{
  /* Visit https://firebase.google.com/docs/database/security to learn more about security rules. */
  "rules": {
    ".read": false,
    ".write": false
  }
}

{
  "rules": {
    "reports": {
      // 1. Anyone can see the markers
      ".read": true,
      
      // 2. DISABLE writing to the whole folder at once
      ".write": false, 

      "$report_id": {
        // 3. ONLY allow writing to a SPECIFIC ID
        // !data.exists() = Create a new pin
        // data.exists() = Update (Claim/Release) or Delete
        ".write": "!data.exists() && (now > (data.parent().child('last_post_time').val() + 30000))",
        
        // 4. MUST have these fields to be saved
        ".validate": "newData.hasChildren(['category', 'item', 'loc'])"
      }
    }
  }
}