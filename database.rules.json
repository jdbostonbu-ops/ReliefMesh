{
  "rules": {
    "reports": {
      ".read": true,
      "$report_id": {
       
        ".write": "now > (root.child('last_post_time').val() + 28000)",
        
        
        ".validate": "newData.hasChildren(['category', 'item', 'loc', 'createdAt'])"
      }
    },
    "last_post_time": {
      ".write": "!data.exists() || (now > (data.val() + 29000))"
    }
  }
}