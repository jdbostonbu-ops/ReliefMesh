{
  "rules": {
    "reports": {
     
      ".read": true,
      
      
      "$report_id": {
        
        ".write": true,
        
        
        ".validate": "newData.hasChildren(['type', 'item', 'category', 'loc', 'color']) && (newData.child('type').val() === 'offer' || newData.child('type').val() === 'need')"
      }
    }
  }
}